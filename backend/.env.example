# Used for host-based commands (uv run alembic, uv run uvicorn, uv run pytest)
# against the Postgres container exposed on localhost:5433 (5432 is remapped to
# avoid clashing with a locally installed Postgres, if any).
# The docker-compose "api" service overrides this internally to use the "db" hostname.
DATABASE_URL=postgresql+psycopg://fittrack:fittrack@localhost:5433/fittrack

# JWT auth settings
JWT_SECRET_KEY=change-me-in-local-development-use-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI provider settings.
# AI_PROVIDER=fake uses a deterministic local provider (no credentials needed)
# and is the default for local development and tests. Set AI_PROVIDER=azure to
# use Azure OpenAI; the fields below are then required.
AI_PROVIDER=fake
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# Optional Azure OpenAI request tuning (defaults shown).
AZURE_OPENAI_TIMEOUT_SECONDS=20
AZURE_OPENAI_MAX_RETRIES=2
